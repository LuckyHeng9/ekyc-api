PORT=2000

# Supabase S3-compatible Storage
S3_ENDPOINT=https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3
S3_REGION=ap-southeast-1
S3_BUCKET=ekyc-bucket
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# MongoDB
MONGO_URI=

# CompreFace — self-hosted face recognition (docker-compose sidecar)
# 1. docker-compose up -d
# 2. Open http://localhost:8100 → create a "Face Verification" service
# 3. Paste the service API key below
COMPREFACE_URL=http://localhost:8000
COMPREFACE_API_KEY=
# Similarity threshold 0–1 (default 0.85 = 85%).
# Lower = more permissive, higher = stricter.
COMPREFACE_THRESHOLD=0.85
